# wasiai-agentshop — env contract

# WasiAI A2A gateway (multi-chain since WKH-MULTICHAIN)
WASIAI_A2A_URL=https://wasiai-a2a-production.up.railway.app
WASIAI_FACILITATOR_URL=https://wasiai-facilitator-production.up.railway.app

# ---------------------------------------------------------------------------
# Settlement chain — DEFAULT: Avalanche Fuji USDC (testnet C-chain).
#
# The remittance is liquidated on whatever this block resolves to. Defaults
# target Avalanche Fuji (43113) + native Circle USDC; the self-hosted
# wasiai-facilitator already settles REAL on this chain/asset.
#
# All values are overridable so the same build can target Kite/PYUSD, Base or
# Avalanche mainnet with no code changes. Leave UNSET to use the Fuji defaults.
#
# EIP-712 domain for Fuji USDC (Circle canonical template):
#   name="USD Coin", version="2", verifyingContract=<USDC>, chainId=43113.
#   Source of truth: wasiai-facilitator/src/chains/avalanche.ts (USDC_FUJI).
# ---------------------------------------------------------------------------
# SETTLE_CHAIN_ID=43113
# SETTLE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# SETTLE_ASSET_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65
# SETTLE_ASSET_SYMBOL=USDC
# SETTLE_ASSET_DECIMALS=6
# SETTLE_NETWORK=eip155:43113
# SETTLE_EIP712_DOMAIN_NAME=USD Coin
# SETTLE_EIP712_DOMAIN_VERSION=2
# SETTLE_EXPLORER_TX_URL=https://testnet.snowtrace.io/tx/{tx}
# SETTLE_NETWORK_LABEL=Avalanche Fuji testnet
# Client-exposed explorer template for the trace console (must be NEXT_PUBLIC_*):
# NEXT_PUBLIC_SETTLE_EXPLORER_TX_URL=https://testnet.snowtrace.io/tx/{tx}

# Legacy Kite / PYUSD vars — kept for back-compat only. NO LONGER the
# settlement chain by default (see SETTLE_* above). To settle on Kite/PYUSD,
# set the SETTLE_* block to Kite values instead of relying on these.
KITE_CHAIN_ID=2368
KITE_RPC_URL=https://rpc-testnet.gokite.ai/
PYUSD_ADDRESS=0x8E04D099b1a8Dd20E6caD4b2Ab2B405B98242ec9
KITE_EXPLORER_URL=https://testnet.kitescan.ai

# A2A key for owner_ref=agentshop-hackathon-2026 · scoped to Kite chain
# Generate via POST /auth/agent-signup before first real-mode run
A2A_KEY=set-me-after-agentshop-signup

# Demo wallets (testnet only — public addresses)
# SENDER (Maria): firma EIP-3009 server-side con PRIVATE_KEY abajo
NEXT_PUBLIC_SENDER_ADDRESS=0xf432baf1315ccDB23E683B95b03fD54Dd3e447Ba
SENDER_PRIVATE_KEY=set-from-railway-OPERATOR_PRIVATE_KEY

# RECEIVER (Mama in Oaxaca): solo recibe, sin private key
NEXT_PUBLIC_RECEIVER_ADDRESS=0x94DCDb84207724A609B17e4838936832EA59B9eD

# Demo mode determinístico — flip a false cuando A2A_KEY + SENDER_PRIVATE_KEY estén cargadas
NEXT_PUBLIC_DEMO_MODE=true
